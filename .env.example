# Paperclip
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_COMPANY_ID=your-company-id
PAPERCLIP_API_KEY=your-paperclip-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
BOARD_WHATSAPP_NUMBER=whatsapp:+1234567890

# Gmail (via OAuth2)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
BOARD_EMAIL=robert@almawebcreative.com

# Server
PORT=3000
NODE_ENV=production

# Monitor interval (ms) - default 60000 = 60 seconds
MONITOR_INTERVAL=60000

# How many snapshots to keep (24h * 60 polls = 1440)
SNAPSHOT_HISTORY=1440

# Alert sensitivity: all | important | critical
ALERT_SENSITIVITY=important

# Session secret for the board interface
SESSION_SECRET=change-me-to-a-random-secret
